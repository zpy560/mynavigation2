<?xml version="1.0" ?>
<sdf version="1.8">
  <!-- Adapted from gazebosim/ros_gz ros_gz_sim_demos/models/vehicle/model.sdf for Nav2 simulation. -->
  <model name="myworld2_diffbot">
    <pose>0 0 0 0 0 0</pose>

    <link name="base_footprint"/>

    <link name="base_link">
      <pose>0 0 0.18 0 0 0</pose>
      <inertial>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.08</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.12</iyy>
          <iyz>0</iyz>
          <izz>0.16</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.52 0.36 0.18</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.52 0.36 0.18</size>
          </box>
        </geometry>
        <material>
          <ambient>0.18 0.32 0.50 1</ambient>
          <diffuse>0.18 0.32 0.50 1</diffuse>
          <specular>0.08 0.08 0.08 1</specular>
        </material>
      </visual>
    </link>

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose>0 0 0.18 0 0 0</pose>
    </joint>

    <link name="wheel_left_link">
      <pose>0 0.205 0.075 -1.5707 0 0</pose>
      <inertial>
        <mass>0.45</mass>
        <inertia>
          <ixx>0.0012</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0012</iyy>
          <iyz>0</iyz>
          <izz>0.0018</izz>
        </inertia>
      </inertial>
      <collision name="wheel_left_collision">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>100000</mu>
              <mu2>100000</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="wheel_left_visual">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.03 0.03 0.03 1</ambient>
          <diffuse>0.03 0.03 0.03 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="wheel_right_link">
      <pose>0 -0.205 0.075 -1.5707 0 0</pose>
      <inertial>
        <mass>0.45</mass>
        <inertia>
          <ixx>0.0012</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0012</iyy>
          <iyz>0</iyz>
          <izz>0.0018</izz>
        </inertia>
      </inertial>
      <collision name="wheel_right_collision">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>100000</mu>
              <mu2>100000</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="wheel_right_visual">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.03 0.03 0.03 1</ambient>
          <diffuse>0.03 0.03 0.03 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="wheel_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name="wheel_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <link name="rear_caster_link">
      <pose>-0.22 0 0.045 0 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="caster_collision">
        <geometry>
          <sphere>
            <radius>0.045</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="caster_visual">
        <geometry>
          <sphere>
            <radius>0.045</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.03 0.03 0.03 1</ambient>
          <diffuse>0.03 0.03 0.03 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="rear_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>rear_caster_link</child>
    </joint>

    <link name="front_caster_link">
      <pose>0.22 0 0.045 0 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="front_caster_collision">
        <geometry>
          <sphere>
            <radius>0.045</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="front_caster_visual">
        <geometry>
          <sphere>
            <radius>0.045</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.03 0.03 0.03 1</ambient>
          <diffuse>0.03 0.03 0.03 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="front_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_caster_link</child>
    </joint>

    <link name="base_scan">
      <pose>0.18 0 0.31 0 0 0</pose>
      <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.055</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.055</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
      <sensor name="gpu_lidar" type="gpu_lidar">
        <topic>scan</topic>
        <ignition_frame_id>base_scan</ignition_frame_id>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>20.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <always_on>true</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>base_scan</child>
      <pose>0.18 0 0.31 0 0 0</pose>
    </joint>

    <link name="imu_link">
      <pose>0 0 0.26 0 0 0</pose>
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>imu</topic>
        <ignition_frame_id>imu_link</ignition_frame_id>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
      <pose>0 0 0.26 0 0 0</pose>
    </joint>

    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.41</wheel_separation>
      <wheel_radius>0.075</wheel_radius>
      <topic>cmd_vel</topic>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <min_linear_acceleration>-1.0</min_linear_acceleration>
      <max_angular_acceleration>2.5</max_angular_acceleration>
      <min_angular_acceleration>-2.5</min_angular_acceleration>
      <max_linear_velocity>0.6</max_linear_velocity>
      <min_linear_velocity>-0.6</min_linear_velocity>
      <max_angular_velocity>1.5</max_angular_velocity>
      <min_angular_velocity>-1.5</min_angular_velocity>
    </plugin>

    <plugin
      filename="ignition-gazebo-odometry-publisher-system"
      name="ignition::gazebo::systems::OdometryPublisher">
      <odom_publish_frequency>50</odom_publish_frequency>
      <odom_topic>/odom</odom_topic>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <tf_topic>/odom/tf</tf_topic>
      <dimensions>2</dimensions>
    </plugin>

    <plugin
      filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
    </plugin>
  </model>
</sdf>
